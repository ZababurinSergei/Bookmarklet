{
  "manifest_version": 3,
  "name": "Bookmarklet Bridge",
  "version": "1.0.0",
  "description": "Мост между букмарклетами и расширением для получения данных закладок",
  "permissions": ["bookmarks", "storage", "activeTab", "tabs", "system.display"],
  "host_permissions": ["http://localhost/*", "https://*/*", "http://*/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["favicon.ico", "favicon.png", "popup.html", "popup.js", "popup.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Bookmarklet Bridge",
    "default_icon": {
      "16": "favicon.png",
      "48": "favicon.png",
      "128": "favicon.png"
    }
  },
  "icons": {
    "16": "favicon.png",
    "48": "favicon.png",
    "128": "favicon.png"
  }
}
