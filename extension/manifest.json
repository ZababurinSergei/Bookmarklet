{
  "manifest_version": 3,
  "name": "Bookmarklet Bridge",
  "version": "1.0.0",
  "description": "Мост между букмарклетами и расширением для получения данных закладок",
  "permissions": ["bookmarks", "storage", "activeTab", "tabs"],
  "host_permissions": ["http://localhost/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmarklet Bridge",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
